{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=SentraDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "JwtSettings": {
    "SecretKey": "YOUR_SECRET_KEY_MIN_32_CHARS_LONG_HERE",
    "Issuer": "SentraAPI",
    "Audience": "SentraClients",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },

  "ApiKeys": {
    "AiModelKey": "YOUR_AI_MODEL_API_KEY_HERE"
  },

  "Firebase": {
    "CredentialPath": "PATH/TO/firebase-credentials.json"
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://YOUR_PRODUCTION_FRONTEND_URL"
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}